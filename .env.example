# Auth for Claude Code inside the container.
# Use ONE of the supported auth methods for your org (API key shown here).
ANTHROPIC_API_KEY=sk-ant-...

# Orchestrator tuning
POLL_INTERVAL_MS=60000
MAX_CONCURRENT=1

# Paths (defaults are fine inside the container)
# HARNESS_DB=/app/data/harness.duckdb
# HARNESS_LOGS=/app/data/logs

# GitHub (the gh CLI inside the container uses this)
GH_TOKEN=ghp_...
GIT_AUTHOR_NAME=agent-harness
GIT_AUTHOR_EMAIL=agents@yourcorp.example

# Durability on ephemeral platforms: a private git repo that stores DuckDB
# exports, digests, and session logs. The container restores from it on boot
# and checkpoints to it after every run / every CHECKPOINT_MINUTES / on SIGTERM.
# Leave unset for local dev with a docker volume.
STATE_REPO=https://x-access-token:${GH_TOKEN}@github.yourcorp.example/org/harness-state.git
CHECKPOINT_MINUTES=15

# Web
PORT=8080

# --- Secret store (required to store the Jira token via the setup wizard) ---
# Master key used to encrypt secrets at rest. Comes from your secret manager.
# If unset, the wizard refuses to store a token; supply JIRA_API_TOKEN instead.
HARNESS_SECRET_KEY=

# --- Jira (optional; most config is entered in the setup wizard UI) ---
# Stricter alternative to storing the token via the wizard: provide it here and the
# harness will use it without ever persisting a copy. Takes precedence if set.
JIRA_API_TOKEN=

# In-memory DB is the default (HARNESS_DB unset). Set a path only for disk-backed dev.
# HARNESS_DB=:memory:

# --- Continuity / forensic durability ---
# Independent heartbeat interval (drives the lamp + the lock-graph chain).
CONTINUITY_INTERVAL_MS=30000
# How often an in-flight session's transcript is flushed to the state repo.
ARTIFACT_FLUSH_MS=45000

# --- Telemetry sink (commit-volume fix) ---
# High-frequency forensic data (heartbeat chain, in-flight transcripts) goes here
# instead of git. In production point this at a MOUNTED BUCKET (gcsfuse/s3fs);
# the platform handles bucket auth on the mount. Defaults to a local dir.
TELEMETRY_DIR=

# Runnable role order (metadata-driven roles are discovered from roles/ + .agents).
ROLE_ORDER=reviewer,qa,dev,pm,comms
